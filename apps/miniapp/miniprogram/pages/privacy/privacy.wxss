.page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
  background: #edf1f7;
}

.card {
  border: 1rpx solid #dce3ed;
  border-radius: 16rpx;
  background: #ffffff;
  padding: 28rpx;
}

.title {
  display: block;
  color: #162033;
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.paragraph {
  display: block;
  color: #334155;
  font-size: 28rpx;
  line-height: 1.65;
  margin-bottom: 18rpx;
}
