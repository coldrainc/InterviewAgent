.page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.hero,
.section {
  border: 1rpx solid #dce3ed;
  border-radius: 16rpx;
  background: #ffffff;
  padding: 24rpx;
}

.hero {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.eyebrow,
.label {
  display: block;
  color: #687386;
  font-size: 24rpx;
}

.title {
  display: block;
  margin-top: 6rpx;
  color: #162033;
  font-size: 40rpx;
  font-weight: 700;
}

.summary {
  display: block;
  margin-top: 10rpx;
  color: #526177;
  font-size: 26rpx;
  line-height: 1.45;
}

.status,
.link {
  color: #2563eb;
  font-size: 24rpx;
  font-weight: 600;
}

.section {
  display: grid;
  gap: 16rpx;
}

.section-title {
  color: #162033;
  font-size: 30rpx;
  font-weight: 700;
}

.picker-row,
.resume-card {
  min-height: 76rpx;
  border: 1rpx solid #dce3ed;
  border-radius: 12rpx;
  padding: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  color: #162033;
  background: #f7f9fc;
}

.picker-row text:last-child {
  max-width: 430rpx;
  color: #2563eb;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.field {
  display: grid;
  gap: 10rpx;
}

.field input,
.field textarea {
  width: 100%;
  border: 1rpx solid #dce3ed;
  border-radius: 12rpx;
  padding: 18rpx;
  box-sizing: border-box;
  color: #162033;
  background: #f7f9fc;
}

.field textarea {
  min-height: 150rpx;
  line-height: 1.55;
}

.resume-card {
  align-items: center;
}

.resume-name {
  display: block;
  max-width: 500rpx;
  margin-top: 8rpx;
  color: #162033;
  font-size: 28rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.primary {
  margin-top: auto;
  color: #ffffff;
  background: #2563eb;
}
