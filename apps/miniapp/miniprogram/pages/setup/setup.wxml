<view class="page">
  <view class="hero">
    <view class="brand-row">
      <image class="brand-icon" src="/assets/app-icon.png" mode="aspectFill" />
      <view>
        <text class="eyebrow">Interview Setup</text>
        <text class="title">面试配置</text>
        <text class="summary">{{setupSummary}}</text>
      </view>
    </view>
    <text class="status">{{healthText}}</text>
  </view>

  <view class="section">
    <text class="section-title">工作方式</text>
    <picker mode="selector" range="{{modeOptions}}" range-key="label" bindchange="onModeChange">
      <view class="picker-row">
        <text>模式</text>
        <text>{{selectedModeLabel}}</text>
      </view>
    </picker>
    <picker mode="selector" range="{{industries}}" range-key="label" bindchange="onIndustryChange">
      <view class="picker-row">
        <text>行业</text>
        <text>{{selectedIndustryLabel}}</text>
      </view>
    </picker>
  </view>

  <view class="section">
    <text class="section-title">岗位目标</text>
    <view class="field">
      <text class="label">目标岗位</text>
      <input value="{{setup.targetRole}}" data-key="targetRole" bindinput="onSetupInput" bindblur="onTargetRoleBlur" placeholder="例如：AI 应用工程师" />
    </view>
    <view class="field">
      <text class="label">级别</text>
      <input value="{{setup.seniority}}" data-key="seniority" bindinput="onSetupInput" placeholder="中级 / 高级" />
    </view>
    <view class="field">
      <text class="label">面试目标</text>
      <textarea value="{{setup.interviewGoal}}" data-key="interviewGoal" bindinput="onSetupInput" auto-height placeholder="希望面试官重点考察哪些方向？" />
    </view>
  </view>

  <view class="section">
    <view class="resume-card" bindtap="openResumePage">
      <view>
        <text class="label">当前简历</text>
        <text class="resume-name">{{selectedResumeName || '未选择简历，点击上传或选择'}}</text>
      </view>
      <text class="link">管理</text>
    </view>
  </view>

  <button class="primary" bindtap="startInterview">回到面试工作台</button>
</view>
