.page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
  background: #eef4f1;
}

.card {
  border: 1rpx solid #d9e5df;
  border-radius: 16rpx;
  background: #ffffff;
  padding: 28rpx;
}

.title {
  display: block;
  color: #14251f;
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.paragraph {
  display: block;
  color: #334640;
  font-size: 28rpx;
  line-height: 1.65;
  margin-bottom: 18rpx;
}
