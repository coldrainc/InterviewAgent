.page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.hero,
.section {
  border: 1rpx solid #d9e5df;
  border-radius: 16rpx;
  background: #ffffff;
  padding: 24rpx;
}

.hero {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.brand-row {
  min-width: 0;
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.brand-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 18rpx;
  flex: 0 0 auto;
}

.eyebrow,
.label {
  display: block;
  color: #64756f;
  font-size: 24rpx;
}

.title {
  display: block;
  margin-top: 6rpx;
  color: #14251f;
  font-size: 40rpx;
  font-weight: 700;
}

.summary {
  display: block;
  margin-top: 10rpx;
  color: #5c6f68;
  font-size: 26rpx;
  line-height: 1.45;
}

.status,
.link {
  color: #2f63e8;
  font-size: 24rpx;
  font-weight: 600;
}

.section {
  display: grid;
  gap: 16rpx;
}

.section-title {
  color: #14251f;
  font-size: 30rpx;
  font-weight: 700;
}

.picker-row,
.resume-card {
  min-height: 76rpx;
  border: 1rpx solid #d9e5df;
  border-radius: 12rpx;
  padding: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  color: #14251f;
  background: #f7faf8;
}

.picker-row text:last-child {
  max-width: 430rpx;
  color: #2f63e8;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.field {
  display: grid;
  gap: 10rpx;
}

.field input,
.field textarea {
  width: 100%;
  border: 1rpx solid #d9e5df;
  border-radius: 12rpx;
  padding: 18rpx;
  box-sizing: border-box;
  color: #14251f;
  background: #f7faf8;
}

.field textarea {
  min-height: 150rpx;
  line-height: 1.55;
}

.resume-card {
  align-items: center;
}

.resume-name {
  display: block;
  max-width: 500rpx;
  margin-top: 8rpx;
  color: #14251f;
  font-size: 28rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.primary {
  margin-top: auto;
  color: #ffffff;
  background: #2f63e8;
}
