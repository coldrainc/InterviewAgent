.page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
  background: #edf1f7;
}

.header,
.resume-card,
.empty,
.notice {
  border: 1rpx solid #dce3ed;
  border-radius: 16rpx;
  background: #ffffff;
  padding: 24rpx;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.eyebrow,
.meta,
.summary {
  display: block;
  color: #687386;
  font-size: 24rpx;
}

.title {
  display: block;
  margin-top: 6rpx;
  color: #162033;
  font-size: 40rpx;
  font-weight: 700;
}

.upload,
.primary {
  color: #ffffff;
  background: #2563eb;
}

.notice {
  margin-bottom: 20rpx;
}

.notice.error {
  color: #991b1b;
  background: #fff7f7;
}

.empty {
  display: grid;
  gap: 16rpx;
}

.empty-title {
  color: #162033;
  font-size: 32rpx;
  font-weight: 700;
}

.empty-text {
  color: #687386;
  font-size: 26rpx;
  line-height: 1.5;
}

.list {
  display: grid;
  gap: 18rpx;
}

.resume-card {
  display: grid;
  gap: 16rpx;
}

.resume-card.active {
  border-color: #93c5fd;
  background: #eff6ff;
}

.card-head {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.name {
  color: #162033;
  font-size: 30rpx;
  font-weight: 700;
}

.badge {
  flex: 0 0 auto;
  color: #2563eb;
  font-size: 22rpx;
}

.meta {
  margin-top: 8rpx;
}

.summary {
  margin-top: 10rpx;
  line-height: 1.5;
}

.danger {
  color: #b91c1c;
  background: #fff7f7;
}
