.page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.header,
.workspace-card,
.composer {
  border: 1rpx solid #d9e5df;
  border-radius: 16rpx;
  background: #ffffff;
  padding: 24rpx;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.brand-row {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.brand-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 18rpx;
  flex: 0 0 auto;
}

.eyebrow,
.label,
.role {
  display: block;
  color: #64756f;
  font-size: 24rpx;
}

.title {
  display: block;
  margin-top: 6rpx;
  color: #14251f;
  font-size: 40rpx;
  font-weight: 700;
}

.status {
  color: #2f63e8;
  font-size: 24rpx;
}

.workspace-card {
  display: grid;
  gap: 16rpx;
}

.field {
  display: grid;
  gap: 10rpx;
}

.primary,
.send,
.secondary {
  color: #ffffff;
  background: #2f63e8;
}

.secondary {
  color: #2f63e8;
  background: #eef5ff;
}

.actions {
  display: grid;
  grid-template-columns: 160rpx minmax(0, 1fr);
  gap: 14rpx;
}

.setup-summary,
.resume-strip {
  border: 1rpx solid #d9e5df;
  border-radius: 12rpx;
  padding: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  background: #f7faf8;
}

.summary-text {
  display: block;
  margin-top: 8rpx;
  color: #14251f;
  font-size: 28rpx;
  line-height: 1.45;
}

.resume-name {
  display: block;
  max-width: 500rpx;
  margin-top: 8rpx;
  color: #14251f;
  font-size: 28rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.link {
  color: #2f63e8;
  font-size: 26rpx;
  font-weight: 600;
}

.messages {
  min-height: 0;
  flex: 1;
}

.message {
  margin-bottom: 18rpx;
}

.bubble {
  display: block;
  margin-top: 8rpx;
  border-radius: 16rpx;
  padding: 18rpx;
  color: #14251f;
  background: #ffffff;
  line-height: 1.55;
  white-space: pre-wrap;
}

.message.user .bubble {
  color: #ffffff;
  background: #2f63e8;
}

.message.system .bubble {
  color: #92400e;
  background: #fffaf0;
}

.composer {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 128rpx;
  gap: 14rpx;
  align-items: end;
}

.composer textarea {
  width: 100%;
  min-height: 72rpx;
  max-height: 220rpx;
}
