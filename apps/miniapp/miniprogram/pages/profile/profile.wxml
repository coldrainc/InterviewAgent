<view class="page">
  <view class="header">
    <view>
      <text class="eyebrow">Account</text>
      <text class="title">我的</text>
    </view>
    <button class="refresh" loading="{{loading}}" bindtap="load">刷新</button>
  </view>

  <view wx:if="{{error}}" class="notice error">{{error}}</view>

  <view class="profile-card {{me && me.authenticated ? 'signed' : ''}}">
    <view class="avatar">{{me && me.authenticated ? '我' : '未'}}</view>
    <view class="profile-main">
      <text class="value">{{account ? (account.display_name || account.user_id) : '未登录'}}</text>
      <text class="meta">{{account ? (account.email || account.user_id) : '登录后保存简历、会话和用量记录'}}</text>
    </view>
  </view>

  <view class="card quota-card">
    <text class="label">权益</text>
    <view class="quota-grid">
      <view>
        <text class="meta">剩余试用</text>
        <text class="quota-value">{{account ? account.trial_uses_remaining : '-'}}</text>
      </view>
      <view>
        <text class="meta">积分余额</text>
        <text class="quota-value">{{account ? account.credit_balance : '-'}}</text>
      </view>
    </view>
    <view class="recharge-grid">
      <block wx:for="{{rechargeOptions}}" wx:key="*this">
        <button class="recharge" data-amount="{{item}}" loading="{{loading}}" bindtap="recharge">充 {{item}}</button>
      </block>
    </view>
    <text wx:if="{{rechargeStatus}}" class="success">{{rechargeStatus}}</text>
  </view>

  <view class="card">
    <text class="label">账号信息</text>
    <text class="meta">租户：{{account ? account.tenant_id : '-'}}</text>
    <text class="meta">用户：{{account ? account.user_id : '-'}}</text>
    <text class="meta">平台：{{account ? account.platform : '-'}}</text>
  </view>

  <view class="card">
    <text class="label">服务状态</text>
    <text class="value">{{health ? health.status : '-'}}</text>
    <text class="meta">Embedding：{{health ? health.embedding_service_url : '-'}}</text>
    <text class="meta">对象存储：{{health ? health.object_storage_backend : '-'}}</text>
  </view>

  <view class="actions">
    <button class="primary" loading="{{loading}}" bindtap="wechatLogin">微信登录</button>
    <button class="primary" loading="{{loading}}" bindtap="devLogin">开发登录</button>
    <button class="secondary" bindtap="openPrivacy">隐私说明</button>
    <button class="danger" bindtap="logout">清除本地登录</button>
  </view>
</view>
