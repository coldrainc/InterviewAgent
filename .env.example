# Chat model provider. Codex config is also read by default.
OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-5.5
GATEWAY_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ARK_API_KEY=
MOONSHOT_API_KEY=
XAI_API_KEY=

# RAG / vector store
INTERVIEW_VECTOR_STORE=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=interview_agent

# Production-style persistence
DATABASE_URL=postgresql+asyncpg://interview_agent:interview_agent@localhost:5432/interview_agent
INTERVIEW_STORAGE_BACKEND=database
INTERVIEW_OBJECT_STORAGE_BACKEND=minio

# Object storage for original uploaded files
OBJECT_STORAGE_ENDPOINT=localhost:9002
OBJECT_STORAGE_ACCESS_KEY=interview_agent
OBJECT_STORAGE_SECRET_KEY=interview_agent_password
OBJECT_STORAGE_BUCKET=interview-agent
OBJECT_STORAGE_SECURE=false

# API security
# Development default keeps local desktop usable without auth.
# Production should set INTERVIEW_API_AUTH_REQUIRED=true and configure tokens.
INTERVIEW_ENV=development
INTERVIEW_API_AUTH_REQUIRED=false
# Format: token:tenant_id:role,another-token:another-tenant:role
INTERVIEW_API_TOKENS=dev-token:default
INTERVIEW_ADMIN_API_TOKENS=
INTERVIEW_DEFAULT_TENANT_ID=default
INTERVIEW_AUTH_TOKEN_SECRET=dev-secret-change-me
INTERVIEW_AUTH_TOKEN_TTL_SECONDS=604800
INTERVIEW_AUTH_DEV_LOGIN_ENABLED=true
INTERVIEW_AUTH_MOCK_PROVIDER_LOGIN_ENABLED=false
INTERVIEW_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
WECHAT_MINIAPP_APP_ID=
WECHAT_MINIAPP_APP_SECRET=
WECHAT_CODE2SESSION_URL=https://api.weixin.qq.com/sns/jscode2session

# Account / billing
# New registered accounts receive two generation trials. After that, usage is
# charged by input/output token estimates or provider usage metadata.
INTERVIEW_TRIAL_USES=2
INTERVIEW_CREDIT_USD_RATE=100
INTERVIEW_ALLOW_MOCK_RECHARGE=true
INTERVIEW_PAYMENT_WEBHOOK_SECRET=
INTERVIEW_MAX_RECHARGE_CREDITS=10000

INTERVIEW_MAX_UPLOAD_BYTES=5242880
INTERVIEW_MAX_MESSAGE_CHARS=8000
INTERVIEW_RATE_LIMIT_PER_MINUTE=60
INTERVIEW_STORE_UPLOAD_SOURCE_PATH=false

# Embedding
EMBEDDING_PROVIDER=service
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_SERVICE_URL=http://127.0.0.1:8010

# Paths
INTERVIEW_KNOWLEDGE_BASE=knowledge_base/ai-interview-guide/docs
INTERVIEW_RAG_INDEX=.interview_agent/rag_index.json
INTERVIEW_RAG_VECTORS=.interview_agent/rag_vectors.json
INTERVIEW_VECTOR_STORE_METADATA=.interview_agent/vector_store.json
INTERVIEW_MEMORY_PATH=.interview_agent/memory

# Retrieval
RAG_TOP_K=4
RAG_MAX_CHARS=6000
